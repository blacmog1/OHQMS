# OHAQRS - Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=ep-polished-band-ataoop94.c-9.us-east-1.aws.neon.tech
DB_PORT=5432
DB_USER=neondb_owner
DB_PASS=npg_k1DW5FlSLIwt
DB_NAME=neondb
DB_SSLMODE=require

# ============================================
# APPLICATION ENVIRONMENT
# ============================================
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:5173
BACKEND_URL=http://127.0.0.1:8000

# ============================================
# CORS & SECURITY
# ============================================
CORS_ALLOWED_ORIGINS=https://development-of-an-automated-patient.vercel.app,http://localhost:5173,http://localhost:3000
CSRF_TOKEN_LENGTH=32
SESSION_LIFETIME=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT_REQUESTS=5
LOGIN_RATE_LIMIT_WINDOW=300

# ============================================
# EMAIL NOTIFICATIONS (optional)
# ============================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM_ADDRESS=noreply@ohaqrs.local
MAIL_FROM_NAME=OHAQRS Hospital Queue System

# ============================================
# JWT & SECURITY TOKENS
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_PATH=/var/log/ohaqrs
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=10

# ============================================
# REDIS CACHING (optional)
# ============================================
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================
# 2FA & SECURITY
# ============================================
TWO_FACTOR_ENABLED=false
TWO_FACTOR_ISSUER=OHAQRS
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false

# ============================================
# PHONE NOTIFICATIONS (optional)
# ============================================
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_account_sid
SMS_AUTH_TOKEN=your_auth_token
SMS_FROM_NUMBER=+1234567890
