# Database provider: local | neon
DB_PROVIDER=neon

# Neon (cloud - share DATABASE_URL with your team)
PGHOST=your-project.region.aws.neon.tech
PGPORT=5432
PGUSER=neondb_owner
PGPASSWORD=your_neon_password
PGDATABASE=neondb
PGSSLMODE=require
DATABASE_URL=postgresql://neondb_owner:your_neon_password@your-project.region.aws.neon.tech/neondb?sslmode=require

# Local PostgreSQL (optional fallback)
# DB_PROVIDER=local
# PGHOST=127.0.0.1
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your_local_password
# PGDATABASE=hospital_queue
# DATABASE_URL=postgresql://postgres:your_local_password@127.0.0.1:5432/hospital_queue

# Local psql executable path
PSQL_PATH=C:\Program Files\PostgreSQL\18\bin\psql.exe
